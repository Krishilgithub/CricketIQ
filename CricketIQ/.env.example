# ─────────────────────────────────────────────────────────────────────────────
#  CricketIQ  —  Environment Variables Template
#  Copy this file to .env and fill in real values.
#  Never commit .env to version control!
# ─────────────────────────────────────────────────────────────────────────────

# ── OpenAI / GenAI ───────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key-here

# ── MLflow Tracking ──────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5050

# ── DuckDB ───────────────────────────────────────────────────────────────────
DUCKDB_PATH=artifacts/cricketiq.duckdb

# ── Data Paths (override config.yaml defaults if needed) ─────────────────────
CRICSHEET_DATA_PATH=data/raw/cricsheet_csv_all
GIVEN_DATA_PATH=data/raw/given_data_csv
PROCESSED_DATA_PATH=data/processed/cricsheet_csv_men

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Prefect Orchestration (optional) ─────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── Optional: External Live Cricket Feed ─────────────────────────────────────
# LIVE_FEED_API_KEY=your-live-feed-key-here
# LIVE_FEED_BASE_URL=https://api.cricketdata.org


